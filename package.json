{
  "name": "vite-plugin-minify-css-strings",
  "version": "1.2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "author": "lindi0v",
  "license": "CC0-1.0",
  "description": "Vite plugin that minifies CSS inside template literals marked with /* css */ at build time",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vite": ">=4"
  },
  "dependencies": {
    "lightningcss": "^1.32.0",
    "magic-string": "^0.30.21",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
